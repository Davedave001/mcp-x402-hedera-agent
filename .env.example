# Hedera operator credentials — never commit real keys
HEDERA_ACCOUNT_ID=0.0.XXXXXX
HEDERA_PRIVATE_KEY=302e...
HEDERA_NETWORK=testnet

# x402 — EVM address that receives USDC payments on Base
PAYMENT_RECIPIENT_ADDRESS=0xYourEVMAddress

# ── Local dev only ─────────────────────────────────────────────────────────────
# Set this in packages/ui/.env to point the frontend at the local agent server.
# In production, leave unset — nginx proxies /agent/* to AGENT_BACKEND_URL.
VITE_AGENT_URL=http://localhost:3001

# ── Production (nginx container env var) ──────────────────────────────────────
# Set AGENT_BACKEND_URL on the nginx container at runtime (Docker -e flag or
# Railway/Render env vars). The nginx config template substitutes this value
# so the frontend proxy knows where to forward /agent/* requests.
AGENT_BACKEND_URL=https://your-agent.up.railway.app
